---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import PostArticle from '../components/PostArticle.astro';

export async function getStaticPaths() {
	const posts = await getCollection('posts', ({ data }) =>
		import.meta.env.PROD ? !data.draft : true
	);

	return posts.map((post) => ({
		params: { slug: post.data.slug || post.id },
		props: { post }
	}));
}

const { post } = Astro.props;
---

<Base title={post.data.title} description={post.data.description || ''}>
	<PostArticle post={post}>
		<a href="/" class="btn-secondary rounded-full text-sm mt-8 inline-flex no-underline">← Back to posts</a>
	</PostArticle>
</Base>
