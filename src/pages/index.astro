---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import PostArticle from '../components/PostArticle.astro';

const posts = await getCollection('posts', ({ data }) => {
	if (data.page) return false;
	return import.meta.env.PROD ? !data.draft : true;
});

posts.sort((a, b) => {
	const aTime = a.data.datePublished?.getTime() ?? 0;
	const bTime = b.data.datePublished?.getTime() ?? 0;
	return bTime - aTime;
});
---

<Base title="btsv">
	{
		posts.length === 0 ? (
			<p class="text-muted-foreground">No posts yet.</p>
		) : (
			<div class="flex flex-col gap-12">
				{posts.map((post) => (
					<PostArticle post={post} titleAsLink={true} lineClamp={7}>
						<a href={`/${post.data.slug || post.id}`} class="btn-secondary rounded-full text-sm mt-6 inline-flex no-underline">
							Read more →
						</a>
					</PostArticle>
				))}
			</div>
		)
	}
</Base>
