---
import { render } from 'astro:content';
import Callout from './Callout.astro';
import Figure from './Figure.astro';

interface Props {
	post: any;
	titleAsLink?: boolean;
	lineClamp?: number;
}

const { post, titleAsLink = false, lineClamp } = Astro.props;
const { Content } = await render(post);
const published = post.data.datePublished;
const slug = post.data.slug || post.id;
const clampClass = lineClamp ? 'line-clamp-[var(--lines)]' : '';
---

<article class="max-w-2xl mx-auto w-full">
	<header class="mb-8">
		<h2 class="text-2xl font-bold m-0 mb-3">
			{titleAsLink ? (
				<a href={`/${slug}`} class="no-underline text-foreground hover:text-primary">{post.data.title}</a>
			) : (
				<span class="text-foreground">{post.data.title}</span>
			)}
		</h2>
		{post.data.description && (
			<p class="text-sm italic text-muted-foreground">{post.data.description}</p>
		)}
		<div class="flex items-center gap-4 text-sm text-muted-foreground mb-4">
			{published && (
				<time datetime={published.toISOString()}>
					{published.toLocaleDateString('en-US', {
						year: 'numeric',
						month: 'long',
						day: 'numeric'
					})}
				</time>
			)}
		</div>
		{post.data.tags.length > 0 && (
			<div class="flex items-center gap-1.5 flex-wrap">
				{post.data.tags.map((tag) => (
					<a href={`/tags/${tag}`} class="tag">{tag}</a>
				))}
			</div>
		)}
	</header>

	<div class={`prose ${clampClass}`} style={lineClamp ? `--lines: ${lineClamp}` : undefined}>
		<Content components={{ Callout, Figure }} />
	</div>

	<slot />
</article>
