---
interface Props {
	type: 'info' | 'warning' | 'tip';
}

const { type = 'info' } = Astro.props;

const icons = { info: 'ℹ️', warning: '⚠️', tip: '💡' };
const labels = { info: 'Info', warning: 'Warning', tip: 'Tip' };
---

<aside class={`callout callout-${type} grid grid-cols-[auto_1fr] gap-y-1 gap-x-3 px-4 py-3 my-4 rounded-lg text-[0.9375rem] leading-relaxed`} role="note">
	<span class="text-base self-start pt-0.5">{icons[type]}</span>
	<span class="font-semibold text-[0.8125rem] uppercase tracking-wider col-start-2 self-center">{labels[type]}</span>
	<div class="col-start-2 callout-content">
		<slot />
	</div>
</aside>

<style>
	.callout-content > :first-child {
		margin-top: 0;
	}
	.callout-content > :last-child {
		margin-bottom: 0;
	}

	.callout-info {
		background: color-mix(in srgb, #3b82f6 8%, transparent);
		border: 1px solid color-mix(in srgb, #3b82f6 20%, transparent);
	}

	.callout-warning {
		background: color-mix(in srgb, #f59e0b 8%, transparent);
		border: 1px solid color-mix(in srgb, #f59e0b 20%, transparent);
	}

	.callout-tip {
		background: color-mix(in srgb, #10b981 8%, transparent);
		border: 1px solid color-mix(in srgb, #10b981 20%, transparent);
	}

	@media (prefers-color-scheme: dark) {
		.callout-info {
			background: color-mix(in srgb, #60a5fa 10%, transparent);
			border-color: color-mix(in srgb, #60a5fa 25%, transparent);
		}

		.callout-warning {
			background: color-mix(in srgb, #fbbf24 10%, transparent);
			border-color: color-mix(in srgb, #fbbf24 25%, transparent);
		}

		.callout-tip {
			background: color-mix(in srgb, #34d399 10%, transparent);
			border-color: color-mix(in srgb, #34d399 25%, transparent);
		}
	}
</style>
