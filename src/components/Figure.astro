---
interface Props {
	src: string;
	alt: string;
	caption: string;
}

const { src, alt, caption = '' } = Astro.props;
---

<figure class="my-6 text-center">
	<img src={src} alt={alt} loading="lazy" class="max-w-full h-auto rounded-lg border border-border" />
	{caption && <figcaption class="text-sm text-muted-foreground mt-2">{caption}</figcaption>}
</figure>
